{
    "name": "raise-studio/license-client",
    "description": "Standardized PHP SDK for Raise Studio product license gating",
    "type": "library",
    "license": "proprietary",
    "keywords": ["raise-studio", "license", "sdk", "jwt"],
    "homepage": "https://www.raisestudio.dev",
    "support": {
        "email": "support@raisestudio.dev",
        "issues": "https://github.com/raise-studio/raise-license-client-sdk/issues",
        "source": "https://github.com/raise-studio/raise-license-client-sdk"
    },
    "authors": [
        {
            "name": "Raise Studio",
            "email": "support@raisestudio.dev",
            "homepage": "https://www.raisestudio.dev"
        }
    ],
    "autoload": {
        "psr-4": {
            "RaiseStudio\\License\\": "src/License/",
            "RaiseStudio\\License\\Adapters\\": "src/Adapters/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "RaiseStudio\\License\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.2",
        "firebase/php-jwt": "^6.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "mockery/mockery": "^1.6",
        "illuminate/support": "^11.0",
        "illuminate/http": "^11.0"
    },
    "suggest": {
        "illuminate/support": "For Laravel integration via RaiseStudio\\License\\Adapters\\Laravel adapters",
        "illuminate/http": "For Laravel integration via RaiseStudio\\License\\Adapters\\Laravel adapters"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
