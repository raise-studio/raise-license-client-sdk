{
    "name": "raise-studio/license-client",
    "description": "Standardized PHP SDK for Raise Studio product license gating",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "RaiseStudio\\License\\": "src/License/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "RaiseStudio\\License\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.2",
        "firebase/php-jwt": "^6.0",
        "illuminate/support": "^11.0",
        "illuminate/http": "^11.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "mockery/mockery": "^1.6"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
